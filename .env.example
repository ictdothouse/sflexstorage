# PhotoVault Configuration
PORT=3000
SESSION_SECRET=photovault-secret-change-this-in-production

# Admin Default Credentials
ADMIN_EMAIL=admin@photovault.com
ADMIN_PASSWORD=admin123

# ToyyibPay (Sandbox)
TOYYIBPAY_SECRET_KEY=your-toyyibpay-secret-key
TOYYIBPAY_CATEGORY_CODE=your-category-code
TOYYIBPAY_SANDBOX=true

# Billplz (Sandbox)
BILLPLZ_API_KEY=your-billplz-api-key
BILLPLZ_COLLECTION_ID=your-collection-id
BILLPLZ_SANDBOX=true

# Stripe (Test Mode)
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Watermark Settings
WATERMARK_TEXT=PhotoVault
WATERMARK_OPACITY=0.4

# Image Settings
THUMBNAIL_WIDTH=400
PREVIEW_WIDTH=1200
MAX_UPLOAD_SIZE_MB=100
